{% extends 'base.html.twig' %}

{% block title %}{{ 'activity.title'|trans }}{% endblock %}

{% block body %}
    <section class="py-5" style="padding: 6rem 0;">
        <div class="container">
            <h2 class="section-title fade-in">{{ 'activity.page_title'|trans }}</h2>
            <p class="section-subtitle fade-in">{{ 'activity.subtitle'|trans }}</p>
            <div class="row g-4">
                <div class="col-md-6 col-lg-4">
                    <div class="activity-card scale-in">
                        <img src="{{ asset('assets/img/jardinage.jpg') }}" alt="{{ 'activity.gardening.title'|trans }}" class="activity-image">
                        <div class="activity-card-content">
                            <div class="d-flex align-items-center gap-2 mb-2">
                                <div class="activity-emoji">🪴</div>
                                <h3 class="activity-title mb-0">{{ 'activity.gardening.title'|trans }}</h3>
                            </div>
                            <p class="activity-description">{{ 'activity.gardening.description'|trans }}</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-6 col-lg-4">
                    <div class="activity-card scale-in">
                        <img src="{{ asset('assets/img/arts.jpg') }}" alt="{{ 'activity.arts.title'|trans }}" class="activity-image">
                        <div class="activity-card-content">
                            <div class="d-flex align-items-center gap-2 mb-2">
                                <div class="activity-emoji">🌀</div>
                                <h3 class="activity-title mb-0">{{ 'activity.arts.title'|trans }}</h3>
                            </div>
                            <p class="activity-description">{{ 'activity.arts.description'|trans }}</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-6 col-lg-4">
                    <div class="activity-card scale-in">
                        <img src="{{ asset('assets/img/ling.jpg') }}" alt="{{ 'activity.english.title'|trans }}" class="activity-image">
                        <div class="activity-card-content">
                            <div class="d-flex align-items-center gap-2 mb-2">
                                <div class="activity-emoji">🍴</div>
                                <h3 class="activity-title mb-0">{{ 'activity.english.title'|trans }}</h3>
                            </div>
                            <p class="activity-description">{{ 'activity.english.description'|trans }}</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-6 col-lg-4">
                    <div class="activity-card scale-in">
                        <img src="{{ asset('assets/img/arch.jpg') }}" alt="{{ 'activity.archaeology.title'|trans }}" class="activity-image">
                        <div class="activity-card-content">
                            <div class="d-flex align-items-center gap-2 mb-2">
                                <div class="activity-emoji">🏺</div>
                                <h3 class="activity-title mb-0">{{ 'activity.archaeology.title'|trans }}</h3>
                            </div>
                            <p class="activity-description">{{ 'activity.archaeology.description'|trans }}</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-6 col-lg-4">
                    <div class="activity-card scale-in">
                        <img src="{{ asset('assets/img/geo.jpg') }}" alt="{{ 'activity.geology.title'|trans }}" class="activity-image">
                        <div class="activity-card-content">
                            <div class="d-flex align-items-center gap-2 mb-2">
                                <div class="activity-emoji">⛰️</div>
                                <h3 class="activity-title mb-0">{{ 'activity.geology.title'|trans }}</h3>
                            </div>
                            <p class="activity-description">{{ 'activity.geology.description'|trans }}</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-6 col-lg-4">
                    <div class="activity-card scale-in">
                        <img src="{{ asset('assets/img/sortie.jpg') }}" alt="{{ 'activity.sortie.title'|trans }}" class="activity-image">
                        <div class="activity-card-content">
                            <div class="d-flex align-items-center gap-2 mb-2">
                                <div class="activity-emoji">👣</div>
                                <h3 class="activity-title mb-0">{{ 'activity.sortie.title'|trans }}</h3>
                            </div>
                            <p class="activity-description">{{ 'activity.sortie.description'|trans }}</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
{% endblock %}

