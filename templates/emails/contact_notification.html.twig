<!DOCTYPE html>
<html lang="{{ locale }}">
<head>
    <meta charset="UTF-8">
    <title>{{ 'contact.mail.admin_subject'|trans({'%subject%': contact.subject}) }}</title>
</head>
<body style="font-family: Arial, sans-serif; line-height: 1.6; color: #333;">
    <div style="max-width: 600px; margin: 0 auto; padding: 20px;">
        <div style="background-color: #F58220; color: white; padding: 20px; text-align: center;">
            <h1 style="margin: 0;">ADALEN — Message via le site</h1>
        </div>
        <div style="padding: 20px; background-color: #f9f9f9;">
            <p><strong>Nom :</strong> {{ contact.name }}</p>
            <p><strong>E-mail :</strong> <a href="mailto:{{ contact.email }}">{{ contact.email }}</a></p>
            <p><strong>Sujet :</strong> {{ contact.subject }}</p>
            <hr style="border: none; border-top: 1px solid #ddd;">
            <p><strong>Message :</strong></p>
            <p style="white-space: pre-wrap;">{{ contact.message }}</p>
        </div>
        <p style="font-size: 12px; color: #666; text-align: center;">Répondre à ce message pour joindre directement l’expéditeur.</p>
    </div>
</body>
</html>
